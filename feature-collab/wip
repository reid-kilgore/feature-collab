      --bind="r:transform:$PANOP_DIR/wip _reload > /tmp/wip-rl; pos=\$(grep -n {3} /tmp/wip-rl | head -1 | cut -d: -f1); echo \"reload(cat /tmp/wip-rl)+pos(\${pos:-1})\"" \
