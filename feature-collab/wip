  # clean mode file on exit
  rm -f "$_WIP_MODE_FILE" /tmp/wip-linear-sort
  trap 'rm -f "$_WIP_MODE_FILE" /tmp/wip-linear-sort' EXIT

  echo "$initial" | \
    fzf \
      --delimiter='\t' \
      --with-nth=1,2,5 \
      --header=$'enter: go │ x: block │ d: done │ p: pin │ n: note │ e: plan │ c: claude │ r: refresh │ s/b: sort │ L: linear │ j/k 1-9: nav\nSTATUS     NAME                   BRANCHES' \
      --preview="$PANOP_DIR/wip _preview {3} {4} {5}" \
      --preview-window=right:60%:wrap \
      --no-input \
