cmd_pull() {
  local filter="${1:-}"
  if [[ ! -f "$REMOTES_FILE" ]]; then
    echo "No remotes configured. Create $REMOTES_FILE with lines like:" >&2
    echo "  hourly-dev:/home/ssm-user/panop" >&2
    return 1
  fi
  local count=0
  while IFS=: read -r alias remote_panop; do
    [[ -z "$alias" || "$alias" =~ ^# ]] && continue
    if [[ -n "$filter" && "$alias" != "$filter" ]]; then continue; fi
    echo "Pulling from $alias ($remote_panop)..."
    local local_dir="$PANOP_DIR/remote-$alias"
    mkdir -p "$local_dir"
    # Find all work.txt files on the remote
    local remote_files
    remote_files=$(ssh "$alias" "find '$remote_panop' -name work.txt 2>/dev/null" 2>/dev/null) || {
      echo "  Error: SSH to $alias failed" >&2; continue
    }
    # Clear old remote data
    rm -f "$local_dir/work.txt"
    if [[ -z "$remote_files" ]]; then
      echo "  No work.txt files found on $alias"
      continue
    fi
    local total=0
    while IFS= read -r rf; do
      [[ -z "$rf" ]] && continue
      local remote_repo
      remote_repo=$(basename "$(dirname "$rf")")
      local content
      content=$(ssh "$alias" "cat '$rf'" 2>/dev/null) || continue
      while IFS= read -r line; do
        [[ -z "$line" ]] && continue
        # Validate JSON and inject source/remote_repo, skip DONE/CLOSED
        local status
        status=$(echo "$line" | jq -r '.status // "UNKNOWN"' 2>/dev/null) || continue
        [[ "$status" == "DONE" || "$status" == "CLOSED" ]] && continue
        echo "$line" | jq -c --arg src "$alias" --arg rr "$remote_repo" --arg pa "$(date +%s)" '. + {source: $src, remote_repo: $rr, pulled_at: ($pa | tonumber)}' >> "$local_dir/work.txt" 2>/dev/null || continue
        total=$((total + 1))
      done <<< "$content"
    done <<< "$remote_files"
    echo "  Pulled $total active items from $alias"
    count=$((count + total))
  done < "$REMOTES_FILE"
  echo "Total: $count remote items synced"
}

# ── linear ───────────────────────────────────────────────────────────────────

cmd_pull_linear() {
  if [[ ! -f "$LINEAR_TOKEN_FILE" ]]; then
    echo "No Linear token. Create $LINEAR_TOKEN_FILE with your API key." >&2
    return 1
  fi
  local token
  token=$(cat "$LINEAR_TOKEN_FILE")
  echo "Pulling Linear issues..."
  # Fetch assigned-to-me issues
  local query='{"query":"{ issues(filter: { assignee: { isMe: { eq: true } }, state: { type: { nin: [\"completed\", \"canceled\"] } } }, orderBy: updatedAt, first: 100) { nodes { id identifier title description priority url dueDate state { name type } assignee { name } project { name } parent { identifier title } labels { nodes { name } } updatedAt createdAt } } }"}'
  local response
  response=$(curl -s -X POST https://api.linear.app/graphql \
    -H "Content-Type: application/json" \
    -H "Authorization: $token" \
    -d "$query") || { echo "Error: Linear API request failed" >&2; return 1; }
  # Transform to cache format
  echo "$response" | jq -c '.data.issues.nodes[] | {
    id: .id,
    identifier: .identifier,
    title: .title,
    description: .description,
    priority: .priority,
    url: .url,
    dueDate: .dueDate,
    status: .state.name,
    state_type: .state.type,
    assignee: (.assignee.name // null),
    project: (.project.name // null),
    parent: (if .parent then {identifier: .parent.identifier, title: .parent.title} else null end),
    labels: [.labels.nodes[].name],
    updatedAt: .updatedAt,
    createdAt: .createdAt
  }' > "$LINEAR_CACHE"
  local count
  count=$(wc -l < "$LINEAR_CACHE" | tr -d ' ')
  echo "Pulled $count assigned Linear issues"
  # Also fetch all recent issues (team-wide) for "recent overall" sort
  local query_all='{"query":"{ issues(filter: { state: { type: { nin: [\"completed\", \"canceled\"] } } }, orderBy: updatedAt, first: 100) { nodes { id identifier title description priority url dueDate state { name type } assignee { name } project { name } parent { identifier title } labels { nodes { name } } updatedAt createdAt } } }"}'
  local response_all
  response_all=$(curl -s -X POST https://api.linear.app/graphql \
    -H "Content-Type: application/json" \
    -H "Authorization: $token" \
    -d "$query_all") || { echo "Warning: failed to fetch all issues" >&2; return 0; }
  echo "$response_all" | jq -c '.data.issues.nodes[] | {
    id: .id,
    identifier: .identifier,
    title: .title,
    description: .description,
    priority: .priority,
    url: .url,
    dueDate: .dueDate,
    status: .state.name,
    state_type: .state.type,
    assignee: (.assignee.name // null),
    project: (.project.name // null),
    parent: (if .parent then {identifier: .parent.identifier, title: .parent.title} else null end),
    labels: [.labels.nodes[].name],
    updatedAt: .updatedAt,
    createdAt: .createdAt
  }' > "${LINEAR_CACHE}-all"
  local count_all
  count_all=$(wc -l < "${LINEAR_CACHE}-all" | tr -d ' ')
  echo "Pulled $count_all total Linear issues"
}

_LINEAR_MODES=("recent-mine" "urgent-mine" "due-mine" "recent-all")
_LINEAR_MODE_FILE="/tmp/wip-linear-mode"

_linear_header() {
  local current="$1"
  local labels=("Recent (mine)" "Urgent (mine)" "Due soon" "Recent (all)")
  local header=""
  for i in 0 1 2 3; do
    if [[ "${_LINEAR_MODES[$i]}" == "$current" ]]; then
      header+="[${labels[$i]}]"
    else
      header+=" ${labels[$i]} "
    fi
    [[ $i -lt 3 ]] && header+=" │ "
  done
  echo "$header"
}

# Output sorted Linear issues as tab-delimited lines
cmd__linear_reload() {
  local mode="${1:-recent-mine}"
  local source="$LINEAR_CACHE"
  [[ "$mode" == "recent-all" ]] && source="${LINEAR_CACHE}-all"
  [[ ! -f "$source" ]] && return 0
  case "$mode" in
    recent-mine|recent-all)
      jq -c '.' "$source" | sort -t'"' -k2 -r ;;
    urgent-mine)
      jq -s -c 'sort_by(.priority) | .[]' "$source" ;;
    due-mine)
      jq -s -c '[.[] | select(.dueDate != null)] | sort_by(.dueDate) | .[]' "$source" ;;
  esac | while IFS= read -r issue; do
    local li_id li_title li_status
    li_id=$(echo "$issue" | jq -r '.identifier')
    li_title=$(echo "$issue" | jq -r '.title')
    li_status=$(echo "$issue" | jq -r '.status')
    printf '%s\t%s\t%s\n' "$li_status" "$li_title" "$li_id"
  done
}

# Linear issue picker — standalone overlay
cmd__linear_picker() {
  # Auto-refresh if cache missing or older than 1 hour
  if [[ ! -f "$LINEAR_CACHE" ]] || [[ ! -s "$LINEAR_CACHE" ]] || \
     [[ $(( $(date +%s) - $(stat -f%m "$LINEAR_CACHE") )) -gt 120 ]]; then
    cmd_pull_linear
  fi
  if [[ ! -f "$LINEAR_CACHE" ]] || [[ ! -s "$LINEAR_CACHE" ]]; then
    echo "No Linear issues. Check your token at $LINEAR_TOKEN_FILE" >&2
    return 1
  fi
  echo "recent-mine" > "$_LINEAR_MODE_FILE"
  local initial
  initial=$(cmd__linear_reload recent-mine)
  local selected
  selected=$(printf '%s' "$initial" | fzf \
    --delimiter='\t' \
    --with-nth=1,2 \
    --preview="$PANOP_DIR/wip _preview_linear {3}" \
    --preview-window=right:50%:wrap \
    --border=rounded \
    --border-label=" $(_linear_header recent-mine) " \
    --header=$'enter: start │ ←/→: switch view │ type to filter' \
    --prompt='Linear> ' \
    --no-sort \
    --bind="right:transform:m=\$(cat $_LINEAR_MODE_FILE); case \$m in recent-mine) n=urgent-mine;; urgent-mine) n=due-mine;; due-mine) n=recent-all;; *) n=recent-mine;; esac; echo \$n > $_LINEAR_MODE_FILE; $PANOP_DIR/wip _linear_reload \$n > /tmp/wip-lr; echo \"reload(cat /tmp/wip-lr)+change-border-label( \$($PANOP_DIR/wip _linear_header \$n) )\"" \
    --bind="left:transform:m=\$(cat $_LINEAR_MODE_FILE); case \$m in recent-all) n=due-mine;; due-mine) n=urgent-mine;; urgent-mine) n=recent-mine;; *) n=recent-all;; esac; echo \$n > $_LINEAR_MODE_FILE; $PANOP_DIR/wip _linear_reload \$n > /tmp/wip-lr; echo \"reload(cat /tmp/wip-lr)+change-border-label( \$($PANOP_DIR/wip _linear_header \$n) )\"" \
  )
  rm -f "$_LINEAR_MODE_FILE"
  [[ -z "$selected" ]] && return 0
  local chosen_id
  chosen_id=$(echo "$selected" | awk -F'\t' '{print $3}')
  [[ -z "$chosen_id" ]] && return 0
  # Prompt for branch name, then start
  local issue
  issue=$(grep "\"identifier\":\"$chosen_id\"" "$LINEAR_CACHE" "${LINEAR_CACHE}-all" 2>/dev/null | head -1)
  local title
  title=$(echo "$issue" | jq -r '.title')
  local default_slug
  default_slug=$(echo "$title" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/-/g' | sed 's/--*/-/g' | sed 's/^-//;s/-$//' | cut -c1-40)
  echo ""
  echo "Starting: $chosen_id — $title"
  printf "Branch name [%s]: " "$default_slug"
  read -e branch
  [[ -z "$branch" ]] && branch="$default_slug"
  "$PANOP_DIR/wip" _start_linear "$chosen_id" "$branch"
}

# Start work on a Linear issue: prompt for branch, gwt in new tmux window, patch PLAN.md
cmd__prompt_linear() {
  local identifier="$1"
  [[ -z "$identifier" ]] && return 1
  local issue
  issue=$(grep "\"identifier\":\"$identifier\"" "$LINEAR_CACHE" 2>/dev/null | head -1)
  [[ -z "$issue" ]] && return 1
  local title
  title=$(echo "$issue" | jq -r '.title')
  local default_slug
  default_slug=$(echo "$title" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/-/g' | sed 's/--*/-/g' | sed 's/^-//;s/-$//' | cut -c1-40)
  # This runs inside fzf execute() which provides a terminal
  echo "Linear: $identifier — $title"
  echo ""
  printf "Branch name: "
  read -e -i "$default_slug" branch
  [ -n "$branch" ] && "$PANOP_DIR/wip" _start_linear "$identifier" "$branch"
}

cmd__start_linear() {
  local identifier="$1"
  local branch_slug="$2"
  [[ -z "$identifier" ]] && return 1
  local issue
  issue=$(grep "\"identifier\":\"$identifier\"" "$LINEAR_CACHE" 2>/dev/null | head -1)
  [[ -z "$issue" ]] && { echo "Issue $identifier not found in cache" >&2; return 1; }
  local title url description project labels parent_info
  title=$(echo "$issue" | jq -r '.title')
  url=$(echo "$issue" | jq -r '.url')
  description=$(echo "$issue" | jq -r '.description // ""')
  project=$(echo "$issue" | jq -r '.project // empty')
  labels=$(echo "$issue" | jq -r '.labels | join(", ")')
  parent_info=$(echo "$issue" | jq -r 'if .parent then "\(.parent.identifier): \(.parent.title)" else empty end')
  [[ -z "$branch_slug" ]] && {
    # Generate default slug from title
    branch_slug=$(echo "$title" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/-/g' | sed 's/--*/-/g' | sed 's/^-//;s/-$//' | cut -c1-40)
  }
  local full_branch="rk-$(date +%m%d)-$branch_slug"
  local hourly_dir="$LINEAR_HOURLY_DIR"
  if [[ ! -d "$hourly_dir" ]]; then
    echo "Error: $hourly_dir not found" >&2; return 1
  fi
  # New tmux window: cd to hourly, run gwt, land in worktree
  local worktree_dir="$hourly_dir/../$full_branch"
  # Write a small launcher so we avoid quoting hell
  cat > /tmp/wip-gwt-launch.sh <<GWTEOF
#!/bin/zsh
cd "$hourly_dir" && gwt "$branch_slug"
cd "$worktree_dir" 2>/dev/null
exec zsh
GWTEOF
  chmod +x /tmp/wip-gwt-launch.sh
  tmux new-window -n "$branch_slug" "zsh /tmp/wip-gwt-launch.sh"
  # Wait for gwt to create the PLAN.md, then patch it with Linear content
  local planfile="$worktree_dir/docs/reidplans/$full_branch/PLAN.md"
  local tries=0
  while [[ ! -f "$planfile" ]] && (( tries < 30 )); do
    sleep 1
    tries=$((tries + 1))
  done
  if [[ ! -f "$planfile" ]]; then
    echo "Warning: PLAN.md not created after 30s" >&2
    return 0
  fi
  # Build metadata block
  local meta=""
  [[ -n "$project" ]] && meta+="Project: $project"$'\n'
  [[ -n "$labels" ]] && meta+="Labels: $labels"$'\n'
  [[ -n "$parent_info" ]] && meta+="Parent: $parent_info"$'\n'
  # Overwrite with Linear issue content
  cat > "$planfile" <<PLANEOF
# $full_branch

> $identifier: $title
> $url
${meta:+
$meta}
## Goal

$title

## Context

$description

## Progress

PLANEOF
  echo "Wrote Linear issue to $planfile"
  # Link the wip item to the Linear issue
  "$PANOP_DIR/wip" set "$full_branch" linear_id "\"$identifier\"" 2>/dev/null || true
}

# ── dispatch ─────────────────────────────────────────────────────────────────

case "${1:-}" in
  help|--help|-h)     cmd_help ;;
  list)               shift; cmd_list "$@" ;;
  get)                shift; cmd_get "$@" ;;
  status)             shift; cmd_status "$@" ;;
  add-branch)         shift; cmd_add_branch "$@" ;;
  branch-status)      shift; cmd_branch_status "$@" ;;
  set)                shift; cmd_set "$@" ;;
  note)               shift; cmd_note "$@" ;;
  notify)             shift; cmd_notify "$@" ;;
  pull)               shift; cmd_pull "$@" ;;
  pull-linear)        cmd_pull_linear ;;
  _prompt_linear)     shift; cmd__prompt_linear "$@" ;;
  _start_linear)      shift; cmd__start_linear "$@" ;;
  _reload)            shift; cmd__reload "$@" ;;
  _preview)           shift; cmd__preview "$@" ;;
  _palette)           shift; cmd__palette "$@" ;;
  _linear_picker)     cmd__linear_picker ;;
  _linear_reload)     shift; cmd__linear_reload "$@" ;;
  _linear_header)     shift; _linear_header "$@" ;;
  _preview_linear)    shift; _preview_linear "$@" ;;
  linear)             cmd__linear_picker ;;
  _toggle_claude)     cmd__toggle_claude ;;
  _toggle_priority)   shift; cmd__toggle_priority "$@" ;;
  "")                 cmd_interactive ;;
  *)                  echo "Unknown command: $1" >&2; echo "Run 'wip help' for usage." >&2; exit 1 ;;
esac
