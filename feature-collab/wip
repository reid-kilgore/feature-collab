# Paginated Linear issue fetcher. Fetches up to 1000 issues in pages of 250.
# Usage: _pull_linear_paginated <filter> <token> <output_file>
_pull_linear_paginated() {
  local filter="$1" token="$2" outfile="$3"
  local cursor="" has_next=true page=0
  local tmpfile="/tmp/wip-linear-page-$$"
  > "$outfile"  # truncate

  while [[ "$has_next" == "true" ]]; do
    local after_clause=""
    [[ -n "$cursor" ]] && after_clause=", after: \\\"$cursor\\\""

    local query="{\"query\":\"{ issues(filter: { $filter }, orderBy: updatedAt, first: 250${after_clause}) { pageInfo { hasNextPage endCursor } nodes { id identifier title description priority url dueDate state { name type } assignee { name } project { name } parent { identifier title } labels { nodes { name } } updatedAt createdAt } } }\"}"

    curl -s -X POST https://api.linear.app/graphql \
      -H "Content-Type: application/json" \
      -H "Authorization: $token" \
      -d "$query" > "$tmpfile" || { echo "Error: Linear API request failed (page $page)" >&2; rm -f "$tmpfile"; return 1; }

    jq -c '.data.issues.nodes[] | {
      id: .id,
      identifier: .identifier,
      title: .title,
      description: .description,
      priority: .priority,
      url: .url,
      dueDate: .dueDate,
      status: .state.name,
      state_type: .state.type,
      assignee: (.assignee.name // null),
      project: (.project.name // null),
      parent: (if .parent then {identifier: .parent.identifier, title: .parent.title} else null end),
      labels: [.labels.nodes[].name],
      updatedAt: .updatedAt,
      createdAt: .createdAt
    }' "$tmpfile" >> "$outfile" || true

    has_next=$(jq -r '.data.issues.pageInfo.hasNextPage // false' "$tmpfile")
    cursor=$(jq -r '.data.issues.pageInfo.endCursor // empty' "$tmpfile")
    page=$((page + 1))

    # Safety cap: 4 pages = 1000 issues max
    [[ $page -ge 4 ]] && break
  done
  rm -f "$tmpfile"
}

cmd_pull_linear() {
  if [[ ! -f "$LINEAR_TOKEN_FILE" ]]; then
    echo "No Linear token. Create $LINEAR_TOKEN_FILE with your API key." >&2
    return 1
  fi
  local token
  token=$(cat "$LINEAR_TOKEN_FILE")
  echo "Pulling Linear issues..."

  # Fetch assigned-to-me issues (paginated)
  _pull_linear_paginated \
    'assignee: { isMe: { eq: true } }, state: { type: { nin: [\"completed\", \"canceled\"] } }' \
    "$token" "$LINEAR_CACHE"
  local count
  count=$(wc -l < "$LINEAR_CACHE" | tr -d ' ')
  echo "Pulled $count assigned Linear issues"

  # Also fetch all recent issues (team-wide, paginated)
  _pull_linear_paginated \
    'state: { type: { nin: [\"completed\", \"canceled\"] } }' \
    "$token" "${LINEAR_CACHE}-all" || { echo "Warning: failed to fetch all issues" >&2; return 0; }
  local count_all
  count_all=$(wc -l < "${LINEAR_CACHE}-all" | tr -d ' ')
  echo "Pulled $count_all total Linear issues"

  # Fetch created-by-me issues (paginated)
  _pull_linear_paginated \
    'creator: { isMe: { eq: true } }, state: { type: { nin: [\"completed\", \"canceled\"] } }' \
    "$token" "${LINEAR_CACHE}-created" || { echo "Warning: failed to fetch created issues" >&2; }
  local count_created
  count_created=$(wc -l < "${LINEAR_CACHE}-created" 2>/dev/null | tr -d ' ')
  echo "Pulled ${count_created:-0} created-by-me Linear issues"

  # Fetch current cycle issues assigned to me
  _pull_linear_cycle "$token" || { echo "Warning: failed to fetch cycle issues" >&2; }
}

# Fetch issues in the current active cycle assigned to me
_pull_linear_cycle() {
  local token="$1"
  local outfile="${LINEAR_CACHE}-cycle"
  > "$outfile"

  # First, find the active cycle
  local cycle_query='{"query":"{ cycles(filter: { isActive: { eq: true } }, first: 1) { nodes { id number startsAt endsAt } } }"}'
  local cycle_response
  cycle_response=$(curl -s -X POST https://api.linear.app/graphql \
    -H "Content-Type: application/json" \
    -H "Authorization: $token" \
    -d "$cycle_query") || { echo "Warning: cycle query failed" >&2; return 1; }

  local cycle_id
  cycle_id=$(echo "$cycle_response" | jq -r '.data.cycles.nodes[0].id // empty')
  if [[ -z "$cycle_id" ]]; then
    echo "No active cycle found" >&2
    return 0
  fi

  # Fetch issues in that cycle assigned to me
  _pull_linear_paginated \
    "cycle: { id: { eq: \\\"$cycle_id\\\" } }, assignee: { isMe: { eq: true } }, state: { type: { nin: [\\\"completed\\\", \\\"canceled\\\"] } }" \
    "$token" "$outfile"

  local count
  count=$(wc -l < "$outfile" | tr -d ' ')
  echo "Pulled $count current cycle issues"
}

_LINEAR_MODES=("created-mine" "cycle-mine" "assigned-mine")
_LINEAR_MODE_FILE="/tmp/wip-linear-mode"

_linear_header() {
  local current="$1"
  local labels=("Created by me" "Current Cycle" "Assigned to me")
  local header=""
  local active=$'\033[40;37m'  # black bg, grey text
  local inactive=$'\033[2m'     # dim
  local reset=$'\033[0m'
  for i in 0 1 2; do
    if [[ "${_LINEAR_MODES[$i]}" == "$current" ]]; then
      header+="${active} ${labels[$i]} ${reset}"
    else
      header+="${inactive} ${labels[$i]} ${reset}"
    fi
    [[ $i -lt 2 ]] && header+=" │ "
  done
  echo "$header"
}

# Output sorted Linear issues as tab-delimited lines
cmd__linear_reload() {
  local mode="${1:-created-mine}"
  local source
  case "$mode" in
    created-mine) source="${LINEAR_CACHE}-created" ;;
    cycle-mine)   source="${LINEAR_CACHE}-cycle" ;;
    assigned-mine) source="$LINEAR_CACHE" ;;
    *) source="$LINEAR_CACHE" ;;
  esac
  [[ ! -f "$source" ]] && return 0
  jq -c '.' "$source" | sort -t'"' -k2 -r | while IFS= read -r issue; do
    local li_id li_title li_status
    li_id=$(echo "$issue" | jq -r '.identifier')
    li_title=$(echo "$issue" | jq -r '.title')
    li_status=$(echo "$issue" | jq -r '.status')
    printf '%s\t%s\t%s\n' "$li_status" "$li_title" "$li_id"
  done
}

# Linear issue picker — standalone overlay
cmd__linear_picker() {
  # Auto-refresh if cache missing or older than 1 hour
  if [[ ! -f "$LINEAR_CACHE" ]] || [[ ! -s "$LINEAR_CACHE" ]] || \
     [[ $(( $(date +%s) - $(stat -f%m "$LINEAR_CACHE") )) -gt 120 ]]; then
    cmd_pull_linear
  fi
  if [[ ! -f "$LINEAR_CACHE" ]] || [[ ! -s "$LINEAR_CACHE" ]]; then
    echo "No Linear issues. Check your token at $LINEAR_TOKEN_FILE" >&2
    return 1
  fi
  echo "created-mine" > "$_LINEAR_MODE_FILE"
  local initial
  initial=$(cmd__linear_reload created-mine)
  local selected
  selected=$(printf '%s' "$initial" | fzf \
    --delimiter='\t' \
    --with-nth=1,2 \
    --preview="$PANOP_DIR/wip _preview_linear {3}" \
    --preview-window=right:50%:wrap \
    --ansi \
    --border=rounded \
    --border-label=" $(_linear_header created-mine) " \
    --header=$'enter: start │ ←/→: switch view │ type to filter' \
    --prompt='Linear> ' \
    --no-sort \
    --bind="right:transform:m=\$(cat $_LINEAR_MODE_FILE); case \$m in created-mine) n=cycle-mine;; cycle-mine) n=assigned-mine;; *) n=created-mine;; esac; echo \$n > $_LINEAR_MODE_FILE; $PANOP_DIR/wip _linear_reload \$n > /tmp/wip-lr; echo \"reload(cat /tmp/wip-lr)+change-border-label( \$($PANOP_DIR/wip _linear_header \$n) )\"" \
    --bind="left:transform:m=\$(cat $_LINEAR_MODE_FILE); case \$m in assigned-mine) n=cycle-mine;; cycle-mine) n=created-mine;; *) n=assigned-mine;; esac; echo \$n > $_LINEAR_MODE_FILE; $PANOP_DIR/wip _linear_reload \$n > /tmp/wip-lr; echo \"reload(cat /tmp/wip-lr)+change-border-label( \$($PANOP_DIR/wip _linear_header \$n) )\"" \
  )
  rm -f "$_LINEAR_MODE_FILE"
  [[ -z "$selected" ]] && return 0
  local chosen_id
  chosen_id=$(echo "$selected" | awk -F'\t' '{print $3}')
  [[ -z "$chosen_id" ]] && return 0
  # Write selection to temp file — the caller (tmux popup binding) will handle the prompt
  echo "$chosen_id" > /tmp/wip-linear-selected
}

# Start work on a Linear issue: prompt for branch, gwt in new tmux window, patch PLAN.md
cmd__prompt_linear() {
  local identifier="$1"
  [[ -z "$identifier" ]] && return 1
  local issue
  issue=$(grep -h "\"identifier\":\"$identifier\"" "$LINEAR_CACHE" "${LINEAR_CACHE}-all" 2>/dev/null | head -1)
  [[ -z "$issue" ]] && return 1
  local title
  title=$(echo "$issue" | jq -r '.title')
  local default_slug
  default_slug=$(echo "$title" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/-/g' | sed 's/--*/-/g' | sed 's/^-//;s/-$//' | cut -c1-40)
  # This runs inside fzf execute() which provides a terminal
  echo "Linear: $identifier — $title"
  echo ""
  printf "Branch name: "
  read -e -i "$default_slug" branch
  [ -n "$branch" ] && "$PANOP_DIR/wip" _start_linear "$identifier" "$branch"
}

cmd__start_linear() {
  local identifier="$1"
  local branch_slug="$2"
  [[ -z "$identifier" ]] && return 1
  local issue
  issue=$(grep -h "\"identifier\":\"$identifier\"" "$LINEAR_CACHE" "${LINEAR_CACHE}-all" 2>/dev/null | head -1)
  [[ -z "$issue" ]] && { echo "Issue $identifier not found in cache" >&2; return 1; }
  local title url description project labels parent_info
  title=$(echo "$issue" | jq -r '.title')
  url=$(echo "$issue" | jq -r '.url')
  description=$(echo "$issue" | jq -r '.description // ""')
  project=$(echo "$issue" | jq -r '.project // empty')
  labels=$(echo "$issue" | jq -r '.labels | join(", ")')
  parent_info=$(echo "$issue" | jq -r 'if .parent then "\(.parent.identifier): \(.parent.title)" else empty end')
  [[ -z "$branch_slug" ]] && {
    # Generate default slug from title
    branch_slug=$(echo "$title" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/-/g' | sed 's/--*/-/g' | sed 's/^-//;s/-$//' | cut -c1-40)
  }
  local full_branch="rk-$(date +%m%d)-$branch_slug"
  local hourly_dir="$LINEAR_HOURLY_DIR"
  if [[ ! -d "$hourly_dir" ]]; then
    echo "Error: $hourly_dir not found" >&2; return 1
  fi
  # New tmux window: cd to hourly, run gwt, land in worktree
  local worktree_dir="$hourly_dir/../$full_branch"
  # Write a small launcher so we avoid quoting hell
  cat > /tmp/wip-gwt-launch.sh <<GWTEOF
#!/bin/zsh
cd "$hourly_dir" && gwt "$branch_slug"
cd "$worktree_dir" 2>/dev/null
exec zsh
GWTEOF
  chmod +x /tmp/wip-gwt-launch.sh
  tmux new-window -n "$branch_slug" "zsh /tmp/wip-gwt-launch.sh"
  # Wait for gwt to create the PLAN.md, then patch it with Linear content
  local planfile="$worktree_dir/docs/reidplans/$full_branch/PLAN.md"
  local tries=0
  while [[ ! -f "$planfile" ]] && (( tries < 30 )); do
    sleep 1
    tries=$((tries + 1))
  done
  if [[ ! -f "$planfile" ]]; then
    echo "Warning: PLAN.md not created after 30s" >&2
    return 0
  fi
  # Build metadata block
  local meta=""
  [[ -n "$project" ]] && meta+="Project: $project"$'\n'
  [[ -n "$labels" ]] && meta+="Labels: $labels"$'\n'
  [[ -n "$parent_info" ]] && meta+="Parent: $parent_info"$'\n'
  # Overwrite with Linear issue content
  cat > "$planfile" <<PLANEOF
# $full_branch

> $identifier: $title
> $url
${meta:+
$meta}
## Goal

$title

## Context

$description

## Progress

PLANEOF
  echo "Wrote Linear issue to $planfile"
  # Link the wip item to the Linear issue
  "$PANOP_DIR/wip" set "$full_branch" linear_id "\"$identifier\"" 2>/dev/null || true
}

