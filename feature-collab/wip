      --bind="d:execute-silent($PANOP_DIR/wip status {3} DONE)+transform:$PANOP_DIR/wip _reload > /tmp/wip-rl; pos=\$(grep -n {3} /tmp/wip-rl | head -1 | cut -d: -f1); echo \"reload(cat /tmp/wip-rl)+pos(\${pos:-1})\"" \
      --bind="p:execute-silent($PANOP_DIR/wip _toggle_priority {3})+transform:$PANOP_DIR/wip _reload > /tmp/wip-rl; pos=\$(grep -n {3} /tmp/wip-rl | head -1 | cut -d: -f1); echo \"reload(cat /tmp/wip-rl)+pos(\${pos:-1})\"" \
      --bind="n:execute-silent(tmux display-popup -h 5 -w 80% -E \"bash -c 'echo \\\"note for {3}:\\\" && echo && read -e note && $PANOP_DIR/wip note {3} \\\"\\\$note\\\"'\")+refresh-preview" \
      --bind="e:execute-silent(tmux split-window -h \"nvim {4}/docs/reidplans/{3}/PLAN.md\")+refresh-preview" \
      --bind="ctrl-n:execute-silent(tmux display-popup -h 5 -w 80% -E \"bash -c 'echo \\\"rename {3} (currently: {2}):\\\" && echo && read -e newname && $PANOP_DIR/wip set {3} friendly_name \\\"\\\$newname\\\"'\")+transform:$PANOP_DIR/wip _reload > /tmp/wip-rl; pos=\$(grep -n {3} /tmp/wip-rl | head -1 | cut -d: -f1); echo \"reload(cat /tmp/wip-rl)+pos(\${pos:-1})\"" \
      --bind="L:execute-silent(tmux display-popup -w 90% -h 80% -E \"$PANOP_DIR/wip _linear_picker\")" \
      --bind="j:down" --bind="k:up" \
      --bind="1:pos(1)" --bind="2:pos(2)" --bind="3:pos(3)" \
      --bind="4:pos(4)" --bind="5:pos(5)" --bind="6:pos(6)" \
      --bind="7:pos(7)" --bind="8:pos(8)" --bind="9:pos(9)" \
      --no-info \
      --pointer=' ' \
      --marker=' ' \
